PORT=5000

# ── Database (one of MongoDB or PostgreSQL — see DB_PROVIDER below) ─────────
# DB_PROVIDER controls which client the app uses. Defaults to "mongo".
# Set to "postgres" once you've run Prisma migrations and seeded data.
DB_PROVIDER=mongo

# Legacy/current MongoDB (still used by default — keep working app intact)
MONGODB_URI=mongodb://localhost:27017/hrms

# Azure PostgreSQL (Prisma) — example format:
# postgresql://user:pass@your-server.postgres.database.azure.com:5432/hrms?sslmode=require
DATABASE_URL=

# ── Azure Blob Storage (profile photos, attendance proofs, reports) ─────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=hrms-files

# ── Azure Queue Storage (background job processing) ─────────────────────────
AZURE_QUEUE_NAME=hrms-jobs

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_in_production
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ALLOWED_EMAIL_DOMAINS=yourcompany.com,example.org
CLIENT_URL=http://localhost:5173

# ── SMTP ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HRMS <no-reply@yourcompany.com>"
BCRYPT_ROUNDS=12
NODE_ENV=development
