// Prisma schema for SmartHRMS
// Mirrors the existing 8 Mongoose models, ported to PostgreSQL
//
// To use:
//   1. Set DATABASE_URL in .env
//   2. Run: npx prisma migrate dev --name init
//   3. Run: npx prisma generate
//   4. Run: npm run db:migrate-from-mongo  (one-time data import)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  Admin
  HR
  Manager
  Employee
}

model User {
  id                       String    @id @default(cuid())
  name                     String
  email                    String    @unique
  passwordHash             String
  role                     UserRole  @default(Employee)
  department               String?
  isEmailVerified          Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpiry  DateTime?
  passwordResetToken       String?
  passwordResetExpiry      DateTime?
  refreshToken             String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  employee       Employee?
  reviewedLeaves LeaveRequest[] @relation("LeaveReviewer")
  reviewedWFH    WFHRequest[]   @relation("WFHReviewer")

  @@index([email])
}

// ─────────────────────────────────────────────────────────────────────────────
// EMPLOYEES
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id                String   @id @default(cuid())
  userId            String   @unique
  employeeId        String   @unique
  department        String
  designation       String
  shift             String   @default("General")
  shiftId           String?
  joinDate          DateTime
  phone             String?
  address           String?
  emergencyContact  String?
  devicePin         String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftRef       Shift?           @relation(fields: [shiftId], references: [id])
  attendanceLogs AttendanceLog[]
  leaves         LeaveRequest[]
  wfhRequests    WFHRequest[]
  leaveBalances  LeaveBalance[]

  @@index([department])
  @@index([employeeId])
  @@index([devicePin])
}

// ─────────────────────────────────────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────────────────────────────────────

enum AttendanceStatus {
  Present
  Absent
  Late
  HalfDay
  Leave
  Holiday
  WeeklyOff
}

enum AttendanceMode {
  Office
  WFH
  Field
  ClientVisit
}

enum RegularizationStatus {
  Pending
  Approved
  Rejected
}

model AttendanceLog {
  id                          String                @id @default(cuid())
  employeeId                  String
  date                        DateTime              @db.Date
  punchIn                     DateTime?
  punchOut                    DateTime?
  workHours                   Float?
  status                      AttendanceStatus      @default(Absent)
  attendanceMode              AttendanceMode?
  punchInLat                  Float?
  punchInLng                  Float?
  punchOutLat                 Float?
  punchOutLng                 Float?
  appPunched                  Boolean               @default(false)
  source                      String                @default("device")
  isRegularized               Boolean               @default(false)
  regularizationReason        String?
  regularizationStatus        RegularizationStatus?
  regularizationRequestedAt   DateTime?
  deviceId                    String?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  device   Device?  @relation(fields: [deviceId], references: [id])

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
}

model RawPunchLog {
  id               String   @id @default(cuid())
  deviceId         String
  employeeDeviceId String
  timestamp        DateTime
  punchType        Int      @default(0)
  raw              String?
  createdAt        DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, employeeDeviceId, timestamp])
  @@index([timestamp])
}

// ─────────────────────────────────────────────────────────────────────────────
// DEVICES (eSSL biometric)
// ─────────────────────────────────────────────────────────────────────────────

enum DeviceStatus {
  Online
  Offline
  Unknown
}

model Device {
  id            String       @id @default(cuid())
  name          String
  ip            String
  port          Int          @default(80)
  serialNumber  String       @unique
  username      String
  passwordHash  String
  etlUsername   String?
  etlPassword   String?
  autoSync      Boolean      @default(false)
  syncInterval  Int          @default(5)
  lastEtlSync   DateTime?
  status        DeviceStatus @default(Unknown)
  lastSync      DateTime?
  lastError     String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  attendanceLogs AttendanceLog[]
  rawPunchLogs   RawPunchLog[]
}

// ─────────────────────────────────────────────────────────────────────────────
// LEAVES
// ─────────────────────────────────────────────────────────────────────────────

model LeaveType {
  id           String   @id @default(cuid())
  name         String   @unique
  daysAllowed  Int
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  balances LeaveBalance[]
  requests LeaveRequest[]
}

model LeaveBalance {
  id           String   @id @default(cuid())
  employeeId   String
  leaveTypeId  String
  year         Int
  allocated    Float    @default(0)
  used         Float    @default(0)
  remaining    Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
}

enum LeaveRequestStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

model LeaveRequest {
  id             String             @id @default(cuid())
  employeeId     String
  leaveTypeId    String
  fromDate       DateTime           @db.Date
  toDate         DateTime           @db.Date
  totalDays      Float
  reason         String
  status         LeaveRequestStatus @default(Pending)
  reviewedById   String?
  reviewedAt     DateTime?
  reviewComment  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType  LeaveType @relation(fields: [leaveTypeId], references: [id])
  reviewedBy User?     @relation("LeaveReviewer", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// WFH REQUESTS
// ─────────────────────────────────────────────────────────────────────────────

enum WFHMode {
  WFH
  Field
  ClientVisit
}

enum WFHRequestStatus {
  Pending
  Approved
  Rejected
}

model WFHRequest {
  id            String           @id @default(cuid())
  employeeId    String
  date          DateTime         @db.Date
  mode          WFHMode
  reason        String
  status        WFHRequestStatus @default(Pending)
  reviewedById  String?
  reviewedAt    DateTime?
  reviewComment String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("WFHReviewer", fields: [reviewedById], references: [id])

  @@index([employeeId, date])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// SHIFTS
// ─────────────────────────────────────────────────────────────────────────────

model Shift {
  id                    String   @id @default(cuid())
  name                  String   @unique
  startTime             String   @default("09:00")
  endTime               String   @default("18:00")
  gracePeriodMinutes    Int      @default(15)
  halfDayThresholdHours Int      @default(4)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  employees Employee[]
}

// ─────────────────────────────────────────────────────────────────────────────
// APP SETTINGS (single row)
// ─────────────────────────────────────────────────────────────────────────────

model AppSettings {
  id                        String   @id @default(cuid())
  allowedEmailDomains       String[] @default([])
  shiftStart                String   @default("09:00")
  shiftEnd                  String   @default("18:00")
  lateThresholdMinutes      Int      @default(15)
  halfDayThresholdHours     Int      @default(4)
  workingDays               String[] @default(["Mon", "Tue", "Wed", "Thu", "Fri"])
  holidays                  Json     @default("[]")
  smtpHost                  String   @default("")
  smtpPort                  Int      @default(587)
  smtpUser                  String   @default("")
  smtpPass                  String   @default("")
  smtpFrom                  String   @default("")
  emailNotificationsEnabled Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}
