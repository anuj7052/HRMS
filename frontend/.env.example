# Microsoft (Azure AD) Sign-In — frontend env
# Copy this file to `.env` and fill in your Azure AD app details

# App Registration > Overview > "Application (client) ID"
VITE_AZURE_AD_CLIENT_ID=

# App Registration > Overview > "Directory (tenant) ID"
# Use "common" to allow any work/school/personal account, or your tenant GUID for single-tenant
VITE_AZURE_AD_TENANT_ID=common
